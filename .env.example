# Zerodha API Configuration
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here

# Zerodha Session Token (obtained via login)
# This will be generated at runtime
ZERODHA_ACCESS_TOKEN=

# Database Configuration
DB_TYPE=sqlite  # Options: sqlite, postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zerodha_trading
DB_USER=admin
DB_PASSWORD=

# SQLite specific (if using SQLite)
SQLITE_DB_PATH=data/trading.db

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Flask Configuration
FLASK_ENV=development  # Options: development, production
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# Application Configuration
APP_PORT=5000
APP_HOST=0.0.0.0

# Scanning Configuration
SCANNER_INTERVAL=60  # seconds between scans
SCANNER_ENABLED=True
MAX_STOCKS_TO_SCAN=500

# Analysis Configuration
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2

# Portfolio Settings
MAX_POSITION_SIZE=5  # % of portfolio per stock
MAX_SECTOR_CONCENTRATION=20  # % of portfolio
STOP_LOSS_PERCENT=2
TARGET_PROFIT_PERCENT=5

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/trading_agent.log

# Notifications
ENABLE_SMS_ALERTS=False
ENABLE_EMAIL_ALERTS=False
ALERT_EMAIL=your_email@example.com

# Market Configuration
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30

# API Rate Limiting
API_RATE_LIMIT=100  # requests per minute
